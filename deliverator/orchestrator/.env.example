# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- required ---
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
GITHUB_TOKEN=REPLACE_WITH_OUTPUT_OF_gh_auth_token
GITHUB_REPO=your-username/your-repo

# --- safety rails ---
MAX_USD_PER_RUN=2.00
MAX_ITERATIONS_PER_ISSUE=6

# --- coder mode: "headless" (Claude Code, recommended) or "oneshot" (any model, no harness) ---
CODER_MODE=headless

# --- independent re-check container (adapt to your stack) ---
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_CMD=pip install -q -e . 2>/dev/null; pip install -q pytest ruff; ruff check . && pytest -q

# --- optional: per-role capped keys (see provision_keys.py) ---
# OPENROUTER_MANAGEMENT_KEY=sk-or-mgmt-REPLACE_ME

# --- optional: Telegram phone control (see README section 7) ---
# TELEGRAM_BOT_TOKEN=8123456:AAE_replace_me
# TELEGRAM_CHAT_ID=123456789
