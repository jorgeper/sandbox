# Copy to .env and fill in. NEVER commit .env (it's gitignored).
# Claude Code auth is NOT configured here — run `claude` once and log in.

# --- required ---
GITHUB_TOKEN=REPLACE_WITH_OUTPUT_OF_gh_auth_token
GITHUB_REPO=your-username/deliverator

# --- concurrency: how many issues may advance at once per pass ---
MAX_PARALLEL=3

# --- live view: role runs appear in a `deliverator` tmux session, one window
#     per (issue, role) — tmux attach -t deliverator. Set 0 to disable;
#     without tmux installed the loop falls back to captured output. ---
TMUX_VIEW=1

# --- runaway guards: wall-clock seconds per role run ---
ROLE_TIMEOUT=900
CODER_TIMEOUT=3600

# --- independent re-check container (adapt to your stack) ---
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_CMD=pip install -q -e . 2>/dev/null; pip install -q pytest ruff; ruff check . && pytest -q
# seconds before the re-check container is killed (parallel runs slow containers down)
SANDBOX_TIMEOUT=300

# --- per-role model overrides (defaults live in .claude/agents/<role>.md) ---
# MODEL_DESIGNER=sonnet
# MODEL_CODER=sonnet
# MODEL_DESIGN_REVIEW_FEASIBILITY=haiku
# MODEL_DESIGN_REVIEW_SECURITY=opus
# MODEL_CODE_REVIEW_CORRECTNESS=haiku
# MODEL_CODE_REVIEW_SECURITY=opus
