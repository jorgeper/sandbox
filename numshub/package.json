{
  "name": "numshub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:rust": "cd src-tauri && cargo test --release",
    "validate": "node scripts/validate.mjs",
    "install:app": "pkill -x numshub; rm -rf /Applications/Numshub.app && ditto src-tauri/target/release/bundle/macos/Numshub.app /Applications/Numshub.app && tccutil reset Accessibility com.numshub.app >/dev/null && echo 'Accessibility grant reset (ad-hoc builds re-key it) — the app will walk you through re-granting.' && open /Applications/Numshub.app"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "tauri-plugin-macos-permissions-api": "^2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
