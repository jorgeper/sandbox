# =============================================================================
# Cloud / VPS deployment — webhook mode, requires HTTPS
# Copy to .env.cloud: cp .env.cloud.example .env.cloud
# =============================================================================

TELEGRAM_BOT_TOKEN=your-token-from-botfather
ANTHROPIC_API_KEY=your-anthropic-api-key
MODE=webhook

# Processor: claude (default) or helloworld
PROCESSOR=claude

# Public HTTPS URL where Telegram will send updates
WEBHOOK_BASE_URL=https://bot.example.com

# Secret token to verify incoming webhook requests are from Telegram
TELEGRAM_WEBHOOK_SECRET=some-random-secret-string

# Mailgun (for email inbound/outbound)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_FROM=Hank <hank@mg.example.com>
