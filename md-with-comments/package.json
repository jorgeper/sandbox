{
  "name": "mdcomments",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "concurrently -k \"tsx server/index.ts\" \"vite\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run --reporter=verbose",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "validate": "tsc --noEmit && npm run test:unit && npm run test:e2e && echo \"VALIDATION: ALL PASSED\""
  },
