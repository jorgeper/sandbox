# --- Auth ---
# "dev" shows a pick-a-user login screen (no Google credentials needed).
# "google" enables real Sign in with Google.
AUTH_MODE=dev

# Comma-separated Gmail addresses with the parent (admin) role.
PARENT_EMAILS=mom@gmail.com,dad@gmail.com

# Required when AUTH_MODE=google. Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public origin of the app, used to build the OAuth redirect URI (e.g. https://buckos.example.com)
APP_ORIGIN=http://localhost:3000

# Secret used to sign session cookies. Required in production — generate with:
#   openssl rand -hex 32
SESSION_SECRET=change-me

# --- Storage ---
# Path to the SQLite database file (directory is created if missing).
DATABASE_PATH=./data/buckos.db

# --- Weekly reset ---
# Day of week the allowance resets: 0=Sunday, 1=Monday, ... 6=Saturday
RESET_DAY=1
# Hour of that day (0-23, server local time)
RESET_HOUR=0

# --- Server ---
PORT=3000

# Test-only: enables POST/DELETE /api/test/clock to freeze time (used by e2e tests).
# Never enable in production.
ENABLE_TEST_CLOCK=0
