# Production config for rippy-rippy.jorgepereira.io (Docker deployment).
# Copy to .env.cloud on the VPS and fill in the secrets.

AUTH_MODE=google

# You and your friends — the only Google accounts that can sign in.
ALLOWED_EMAILS=jorgeper@gmail.com,friend@gmail.com

# Google OAuth web client. Authorized redirect URI must be:
#   https://rippy-rippy.jorgepereira.io/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_ORIGIN=https://rippy-rippy.jorgepereira.io

# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Inside the container; docker-compose mounts the rippy-rippy_data volume here.
DATABASE_PATH=/app/data/rippy.db

PORT=3001
