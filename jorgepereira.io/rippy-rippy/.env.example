# --- Auth ---
# "dev" shows a pick-a-user login screen (no Google credentials needed).
# "google" enables real Sign in with Google.
AUTH_MODE=dev

# Comma-separated Google account emails allowed to sign in — you and your
# friends. Everyone gets their own private workout data.
ALLOWED_EMAILS=jorgeper@gmail.com,friend@gmail.com

# Required when AUTH_MODE=google. Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public origin of the app, used to build the OAuth redirect URI
APP_ORIGIN=http://localhost:3001

# Secret used to sign session cookies. Required — generate with:
#   openssl rand -hex 32
SESSION_SECRET=change-me

# --- Storage ---
# Path to the SQLite database file (directory is created if missing).
DATABASE_PATH=./data/rippy.db

# --- Server ---
PORT=3001
