# =============================================================================
# Telegram VPS Bot — Environment Configuration
# Copy this file to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- Required ---

# Bot token from @BotFather on Telegram (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your-token-from-botfather

# Anthropic API key (https://console.anthropic.com/) — only needed if PROCESSOR=claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Bot mode ---

# polling = bot pulls updates from Telegram (local dev, no public URL needed)
# webhook = Telegram pushes updates to your server (production, requires HTTPS)
MODE=polling

# --- Processor ---

# Which message processor to use:
#   hank       — smart processor with intent detection (default, needs ANTHROPIC_API_KEY)
#   helloworld — echoes messages back, no API keys needed (good for testing)
# PROCESSOR=hank

# --- Access control ---

# Comma-separated list of Telegram user IDs allowed to use the bot.
# If empty or not set, anyone can message the bot.
# Find your ID: message the bot and check the logs for "Message from <name> (id=<number>)"
# ALLOWED_USER_IDS=123456789,987654321

# --- Webhook mode only ---

# Public HTTPS URL where Telegram will send updates (e.g. https://bot.example.com)
# WEBHOOK_BASE_URL=https://bot.example.com

# Secret token to verify incoming webhook requests are from Telegram
# TELEGRAM_WEBHOOK_SECRET=some-random-secret-string

# --- Mailgun (email inbound/outbound) ---

# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_WEBHOOK_SIGNING_KEY=your-webhook-signing-key
# MAILGUN_DOMAIN=hank.jorgepereira.io
# MAILGUN_FROM=Hank <hank@hank.jorgepereira.io>

# Comma-separated email addresses allowed to email Hank (empty = anyone)
# ALLOWED_EMAIL_SENDERS=you@gmail.com,friend@example.com
