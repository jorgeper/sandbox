# =============================================================================
# Local development — polling mode, no public URL needed
# Copy to .env.local: cp .env.local.example .env.local
# =============================================================================

TELEGRAM_BOT_TOKEN=your-token-from-botfather
ANTHROPIC_API_KEY=your-anthropic-api-key
MODE=polling

# Processor: hank (default) or helloworld (no API key needed, good for testing)
PROCESSOR=hank
