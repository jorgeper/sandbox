# Production config for buckos.jorgepereira.io (Docker deployment).
# Copy to .env.cloud on the VPS and fill in the secrets.

AUTH_MODE=google
PARENT_EMAILS=jorgeper@gmail.com,otherparent@gmail.com

# Google OAuth web client. Authorized redirect URI must be:
#   https://buckos.jorgepereira.io/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_ORIGIN=https://buckos.jorgepereira.io

# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Inside the container; docker-compose mounts the buckos_data volume here.
DATABASE_PATH=/app/data/buckos.db

RESET_DAY=1
RESET_HOUR=0
PORT=3000
ENABLE_TEST_CLOCK=0
