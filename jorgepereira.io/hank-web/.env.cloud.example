# =============================================================================
# Hank Web — Cloud deployment
# Copy to .env.cloud: cp .env.cloud.example .env.cloud
# =============================================================================

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Email allowed to access the web UI
ALLOWED_EMAIL=jorgeper@gmail.com

# Secret for signing session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=your-random-secret

# Port (default 8001)
PORT=8001
